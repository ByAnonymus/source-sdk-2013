"VertexLitGeneric"
{
	"$basetexture" "vgui\replay\thumbnails\models\player\soldier\sleeve_red_diffuse"
	"$bumpmap" "vgui\replay\thumbnails\models\player\soldier\soldier_sleeves_normal"

	"$phong" "1"
	"$phongexponent" "20"
	"$phongboost" ".3"	
	"$lightwarptexture" "vgui\replay\thumbnails\models/player/pyro/pyro_lightwarp"
	"$phongfresnelranges"	"[.3 1 8]"

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "10"										// Exponent for phong component of rim lighting	
	"$rimlightboost" ".1"										// Boost for ambient cube component of rim lighting

	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"spy_invis" {}
		"invis" {}
	}
}

