"VertexLitGeneric"
{
	"$basetexture" "vgui/replay/thumbnails/models\player\sniper\sniper_handR"
	"$bumpmap" "vgui/replay/thumbnails/models\player\sniper\sniper_handR_normal"

	"$phong" "1"
	"$phongexponent" "5"
	"$phongboost" ".1"	
	"$lightwarptexture" "vgui/replay/thumbnails/models/player/pyro/Lambert_lightwarp"
	"$phongfresnelranges"	"[.3 1 8]"

	// Rim lighting parameters
